# E2E Test Configuration
# Copy this file to e2e/.env.e2e and fill in your values.
# The .env.e2e file is gitignored and should never be committed.

# Base URL of the app to test against (defaults to http://localhost:3080)
KYNS_BASE_URL=http://localhost:3080

# Test account credentials (must exist in the app before running tests)
KYNS_TEST_EMAIL=your-test-account@example.com
KYNS_TEST_PASSWORD=your-test-password
